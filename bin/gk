#!/usr/bin/env bash
set -euo pipefail

GITHUB_REPO="mjeffrey18/git-kiss"

# Read version from sibling file (installed or repo)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VERSION="$(cat "$SCRIPT_DIR/.git-kiss-version" 2>/dev/null || echo "0.0.0")"

# ─── Defaults ────────────────────────────────────────────────────────────────

DEFAULT_MAIN_BRANCH="main"
DEFAULT_DEVELOP_BRANCH="develop"
DEFAULT_STAGING_BRANCH="staging"
DEFAULT_FEATURE_PREFIX="feature/"
DEFAULT_USE_TAGS="true"
DEFAULT_INITIALS=""
DEFAULT_WORKTREE_COPY=""

# ─── Config Loading ──────────────────────────────────────────────────────────

MAIN_BRANCH="$DEFAULT_MAIN_BRANCH"
DEVELOP_BRANCH="$DEFAULT_DEVELOP_BRANCH"
STAGING_BRANCH="$DEFAULT_STAGING_BRANCH"
FEATURE_PREFIX="$DEFAULT_FEATURE_PREFIX"
USE_TAGS="$DEFAULT_USE_TAGS"
INITIALS="$DEFAULT_INITIALS"
WORKTREE_COPY="$DEFAULT_WORKTREE_COPY"

load_config() {
  local global_config="$HOME/.git-kiss"
  local repo_root
  repo_root="$(git rev-parse --show-toplevel 2>/dev/null || echo "")"
  local repo_config="${repo_root:+$repo_root/.gitkiss}"

  # In a worktree, fall back to the main repo's config
  if [[ -n "$repo_root" && ! -f "${repo_config:-}" ]]; then
    local common_dir
    common_dir="$(git rev-parse --git-common-dir 2>/dev/null || echo "")"
    if [[ -n "$common_dir" ]]; then
      local main_root
      main_root="$(cd "$common_dir" && cd .. && pwd -P)"
      repo_root="$(cd "$repo_root" && pwd -P)"
      if [[ "$main_root" != "$repo_root" && -f "$main_root/.gitkiss" ]]; then
        repo_config="$main_root/.gitkiss"
      fi
    fi
  fi

  # Source global config first, then repo config to override
  if [[ -f "$global_config" ]]; then
    debug "loading global config: $global_config"
    # shellcheck source=/dev/null
    source "$global_config"
  else
    debug "no global config found at $global_config"
  fi
  if [[ -n "$repo_config" && -f "$repo_config" ]]; then
    debug "loading repo config: $repo_config"
    # shellcheck source=/dev/null
    source "$repo_config"
  else
    debug "no repo config found"
  fi
  debug "config: MAIN_BRANCH=$MAIN_BRANCH DEVELOP_BRANCH=${DEVELOP_BRANCH:-} STAGING_BRANCH=${STAGING_BRANCH:-} FEATURE_PREFIX=$FEATURE_PREFIX USE_TAGS=$USE_TAGS INITIALS=${INITIALS:-}"
}

# ─── Helpers ─────────────────────────────────────────────────────────────────

RED=$'\033[0;31m'
GREEN=$'\033[0;32m'
YELLOW=$'\033[0;33m'
BLUE=$'\033[0;34m'
BOLD=$'\033[1m'
NC=$'\033[0m' # No Color

DIM=$'\033[2m'

info()    { echo -e "${BLUE}→${NC} $*"; }
success() { echo -e "${GREEN}✓${NC} $*"; }
warn()    { echo -e "${YELLOW}!${NC} $*"; }
error()   { echo -e "${RED}✗${NC} $*" >&2; }
die()     { error "$@"; exit 1; }
debug()   { [[ "${GK_DEBUG:-}" == "1" ]] && echo -e "${DIM}[debug] $*${NC}" >&2 || true; }

current_branch() {
  git branch --show-current
}

base_branch() {
  if [[ -n "$DEVELOP_BRANCH" ]]; then
    echo "$DEVELOP_BRANCH"
  else
    echo "$MAIN_BRANCH"
  fi
}

require_git_repo() {
  git rev-parse --git-dir &>/dev/null || die "Not a git repository."
}

require_clean_tree() {
  if [[ -n "$(git status --porcelain)" ]]; then
    die "Working tree is dirty. Please commit or stash your changes first."
  fi
}

require_feature_branch() {
  local branch
  branch="$(current_branch)"
  if [[ "$branch" != "${FEATURE_PREFIX}"* ]]; then
    die "Not on a feature branch. Current branch: $branch (expected prefix: ${FEATURE_PREFIX})"
  fi
}

require_branch_config() {
  local var_name="$1"
  local label="$2"
  if [[ -z "${!var_name}" ]]; then
    die "$label is not configured. This command requires the $label to be set in your .gitkiss config."
  fi
}

require_command() {
  local cmd="$1"
  local install_hint="${2:-}"
  if ! command -v "$cmd" &>/dev/null; then
    if [[ -n "$install_hint" ]]; then
      die "'$cmd' is not installed. $install_hint"
    else
      die "'$cmd' is not installed."
    fi
  fi
}

# ─── Version Check ──────────────────────────────────────────────────────────

check_version() {
  local stamp_file="${HOME}/.gk_version_check"
  debug "version check: local=$VERSION stamp=$stamp_file"

  # Only check once per day
  if [[ -f "$stamp_file" ]]; then
    local last_check
    last_check="$(cat "$stamp_file" 2>/dev/null || echo "0")"
    local now
    now="$(date +%s)"
    local elapsed=$(( now - last_check ))
    debug "version check: last_check=${last_check} now=${now} elapsed=${elapsed}s (threshold=86400s)"
    if [[ "$elapsed" -lt 86400 ]]; then
      debug "version check: skipped (checked recently)"
      return
    fi
  else
    debug "version check: no stamp file, first run"
  fi

  # Update timestamp
  date +%s > "$stamp_file" 2>/dev/null || true
  debug "version check: stamp file updated"

  # Fetch latest version from GitHub (timeout 3s, best-effort)
  if ! command -v curl &>/dev/null; then
    debug "version check: curl not found, skipping"
    return
  fi

  debug "version check: fetching remote version from GitHub..."
  local remote_version
  remote_version="$(curl -fsSL --max-time 3 \
    "https://raw.githubusercontent.com/${GITHUB_REPO}/main/bin/.git-kiss-version" 2>/dev/null)" || { debug "version check: fetch failed"; return; }
  remote_version="$(echo "$remote_version" | tr -d '[:space:]')"

  if [[ -z "$remote_version" ]]; then
    debug "version check: empty remote version"
    return
  fi

  debug "version check: remote=$remote_version local=$VERSION"

  # Compare versions (only warn if remote is newer)
  if [[ "$remote_version" != "$VERSION" ]]; then
    local IFS='.'
    local -a local_parts=($VERSION)
    local -a remote_parts=($remote_version)
    local is_newer=false

    for idx in 0 1 2; do
      local l="${local_parts[$idx]:-0}"
      local r="${remote_parts[$idx]:-0}"
      if [[ "$r" -gt "$l" ]]; then
        is_newer=true
        break
      elif [[ "$r" -lt "$l" ]]; then
        break
      fi
    done

    if [[ "$is_newer" == true ]]; then
      debug "version check: update available ($VERSION → $remote_version)"
      echo "" >&2
      warn "Update available: ${BOLD}v${VERSION}${NC} → ${BOLD}v${remote_version}${NC}"
      echo -e "   Run: curl -fsSL https://raw.githubusercontent.com/${GITHUB_REPO}/main/install.sh | bash" >&2
      echo "" >&2
    else
      debug "version check: local is up to date (or newer)"
    fi
  else
    debug "version check: versions match, up to date"
  fi
}

# ─── Commands ────────────────────────────────────────────────────────────────

cmd_nf() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    die "Usage: gk nf <feature-name>"
  fi

  # Replace spaces with hyphens and lowercase
  name="$(echo "$name" | tr '[:upper:]' '[:lower:]' | tr ' ' '-')"

  local base
  base="$(base_branch)"

  info "Checking out $base and pulling latest..."
  git checkout "$base"
  git pull origin "$base" --rebase

  if [[ -n "$INITIALS" ]]; then
    name="${INITIALS}-${name}"
  fi

  local branch_name="${FEATURE_PREFIX}${name}"
  info "Creating branch $branch_name..."
  git checkout -b "$branch_name"

  success "Feature branch $branch_name created from $base."
}

cmd_ff() {
  local force=false
  if [[ "${1:-}" == "--force" ]]; then
    force=true
  fi

  require_clean_tree
  require_feature_branch

  local branch
  branch="$(current_branch)"
  local base
  base="$(base_branch)"

  info "Pulling latest $base..."
  git checkout "$base"
  git pull origin "$base" --rebase

  git checkout "$branch"

  local behind
  behind="$(git rev-list --count HEAD.."$base")"
  if [[ "$behind" -gt 0 ]]; then
    die "Feature branch is $behind commit(s) behind $base. Run 'gk rf' to rebase first."
  fi

  info "Merging $branch into $base..."
  git checkout "$base"
  git merge "$branch" --no-ff -m "Merge branch '$branch' into $base"

  success "Feature $branch merged into $base."

  if [[ "$force" == true ]]; then
    info "Pushing to origin/$base..."
    git push origin "$base"
    success "Pushed to origin/$base."

    info "Deleting feature branch $branch..."
    git branch -d "$branch"
    git push origin --delete "$branch" 2>/dev/null || true

    success "Branch $branch deleted."
  else
    echo ""
    info "Push your changes:"
    echo "  git push"
  fi
}

cmd_cm() {
  local message="${1:-}"
  if [[ -z "$message" ]]; then
    die "Usage: gk cm <message>"
  fi

  if [[ -z "$(git status --porcelain)" ]]; then
    die "Nothing to commit. Working tree is clean."
  fi

  git add -A
  git commit -m "$message"

  success "Committed: $message"
}

cmd_pf() {
  require_feature_branch

  local branch
  branch="$(current_branch)"

  info "Publishing $branch..."
  git push --set-upstream origin "$branch"

  success "Branch $branch published to origin."
}

cmd_pr() {
  require_command "gh" "Install the GitHub CLI: https://cli.github.com"
  require_feature_branch

  local title="${1:-}"
  if [[ -z "$title" ]]; then
    die "Usage: gk pr <title> [gh flags...]"
  fi
  shift

  local base
  base="$(base_branch)"

  info "Creating pull request targeting $base..."
  gh pr create --base "$base" --title "$title" --fill "$@"
}

cmd_dp() {
  local force=false
  if [[ "${1:-}" == "--force" ]]; then
    force=true
  fi

  require_branch_config "DEVELOP_BRANCH" "DEVELOP_BRANCH"

  local current
  current="$(current_branch)"
  if [[ "$current" != "$DEVELOP_BRANCH" ]]; then
    die "You must be on $DEVELOP_BRANCH to deploy to production. Current branch: $current"
  fi

  info "Pulling latest $DEVELOP_BRANCH..."
  git pull origin "$DEVELOP_BRANCH" --rebase

  info "Pulling latest $MAIN_BRANCH..."
  git checkout "$MAIN_BRANCH"
  git pull origin "$MAIN_BRANCH" --rebase

  info "Rebasing $DEVELOP_BRANCH onto $MAIN_BRANCH..."
  git rebase "$DEVELOP_BRANCH"

  if [[ "$USE_TAGS" == "true" ]]; then
    local latest_tag current_release next_release tag

    if git describe --tags --match='v*' &>/dev/null; then
      latest_tag="$(git describe --tags "$(git rev-list --tags='v*' --max-count=1)")"
      current_release="${latest_tag#v}"
      # Increment patch version
      next_release="$(echo "$current_release" | awk -F. '{$NF = $NF + 1;} 1' | sed 's/ /./g')"
    else
      latest_tag="(none)"
      next_release="0.0.1"
    fi

    tag="v${next_release}"

    info "Previous tag: $latest_tag"
    info "New tag: $tag"

    git tag -a "$tag" -m "release $tag"

    success "Production deploy prepared. Tag $tag created."

    if [[ "$force" == true ]]; then
      info "Pushing to origin/$MAIN_BRANCH with tags..."
      git push --follow-tags origin "$MAIN_BRANCH"
      success "Here we go again, shipping to production. Hold onto your hats."
    else
      echo ""
      read -r -p "Push to origin/$MAIN_BRANCH with tags? [y/N] " answer
      if [[ "$answer" == [yY] ]]; then
        git push --follow-tags origin "$MAIN_BRANCH"
        success "Here we go again, shipping to production. Hold onto your hats."
      else
        echo ""
        info "Push with tags:"
        echo "  git push --follow-tags"
      fi
    fi
  else
    success "Production deploy prepared."

    if [[ "$force" == true ]]; then
      info "Pushing to origin/$MAIN_BRANCH..."
      git push origin "$MAIN_BRANCH"
      success "Here we go again, shipping to production. Hold onto your hats."
    else
      echo ""
      read -r -p "Push to origin/$MAIN_BRANCH? [y/N] " answer
      if [[ "$answer" == [yY] ]]; then
        git push origin "$MAIN_BRANCH"
        success "Here we go again, shipping to production. Hold onto your hats."
      else
        echo ""
        info "Push your changes:"
        echo "  git push"
      fi
    fi
  fi
}

cmd_ds() {
  local force=false
  if [[ "${1:-}" == "--force" ]]; then
    force=true
  fi

  require_branch_config "STAGING_BRANCH" "STAGING_BRANCH"
  require_feature_branch
  require_clean_tree

  local branch
  branch="$(current_branch)"
  local base
  base="$(base_branch)"

  info "Rebasing $branch against $base..."
  git rebase "$base"

  info "Pulling latest $STAGING_BRANCH..."
  git checkout "$STAGING_BRANCH"
  git pull origin "$STAGING_BRANCH" --rebase

  info "Rebasing $STAGING_BRANCH onto $branch..."
  git rebase "$branch"

  success "Staging prepared with changes from $branch."

  if [[ "$force" == true ]]; then
    info "Force pushing to origin/$STAGING_BRANCH..."
    git push --force origin "$STAGING_BRANCH"
    success "Shipping to staging! Let's hope we don't take down the DB this time..."
  else
    echo ""
    read -r -p "Force push to origin/$STAGING_BRANCH? [y/N] " answer
    if [[ "$answer" == [yY] ]]; then
      git push --force origin "$STAGING_BRANCH"
      success "Shipping to staging! Let's hope we don't take down the DB this time..."
    else
      echo ""
      info "Force push staging:"
      echo "  git push --force"
    fi
  fi
}

cmd_fs() {
  local force=false
  if [[ "${1:-}" == "--force" ]]; then
    force=true
  fi

  require_feature_branch
  require_clean_tree

  local branch base merge_base commit_count
  branch="$(current_branch)"
  base="$(base_branch)"

  merge_base="$(git merge-base "$base" HEAD)"
  commit_count="$(git rev-list --count "$merge_base..HEAD")"

  if [[ "$commit_count" -le 1 ]]; then
    success "Only $commit_count commit(s) on this branch — nothing to squash."
    return
  fi

  if [[ "$force" == false ]]; then
    echo ""
    info "Squashing $commit_count commits on $branch:"
    echo ""
    git --no-pager log --oneline "$merge_base..HEAD"
    echo ""
    read -r -p "Proceed? [y/N] " answer
    if [[ "$answer" != [yY] ]]; then
      info "Aborted."
      return
    fi
  fi

  local messages
  messages="$(git log --reverse --format='- %s' "$merge_base..HEAD")"

  git reset --soft "$merge_base"
  git commit -m "$(printf '%s\n\n%s' "$branch" "$messages")"

  success "$commit_count commits squashed into one on $branch."
}

cmd_rf() {
  require_feature_branch
  require_clean_tree

  local branch
  branch="$(current_branch)"
  local base
  base="$(base_branch)"

  info "Pulling latest $base..."
  git checkout "$base"
  git pull origin "$base" --rebase

  info "Rebasing $branch onto $base..."
  git checkout "$branch"
  git rebase "$base"

  success "Branch $branch is up to date with $base."
}

cmd_init() {
  local repo_root
  repo_root="$(git rev-parse --show-toplevel 2>/dev/null || die "Not a git repository.")"
  local config_path="$repo_root/.gitkiss"

  if [[ -f "$config_path" ]]; then
    warn "Config file already exists at $config_path"
    read -r -p "Overwrite? [y/N] " answer
    if [[ "$answer" != [yY] ]]; then
      info "Aborted."
      return
    fi
  fi

  echo ""
  echo -e "${BOLD}Choose your git flow:${NC}"
  echo ""
  echo "  1) Full flow  (main → develop → feature/* with staging and release tags)"
  echo "  2) Simple flow (main → feature/* with no develop branch)"
  echo ""
  read -r -p "Select [1/2]: " flow

  echo ""
  read -r -p "Your initials (leave blank to skip): " initials

  case "$flow" in
    2)
      cat > "$config_path" <<EOF
# git-kiss config
# Docs: https://github.com/mjeffrey18/git-kiss

MAIN_BRANCH=main
DEVELOP_BRANCH=
STAGING_BRANCH=
FEATURE_PREFIX=feature/
USE_TAGS=false
INITIALS=${initials}
WORKTREE_COPY=
EOF
      success "Simple flow config written to $config_path"
      ;;
    *)
      cat > "$config_path" <<EOF
# git-kiss config
# Docs: https://github.com/mjeffrey18/git-kiss

MAIN_BRANCH=main
DEVELOP_BRANCH=develop
STAGING_BRANCH=staging
FEATURE_PREFIX=feature/
USE_TAGS=true
INITIALS=${initials}
WORKTREE_COPY=
EOF
      success "Full flow config written to $config_path"
      ;;
  esac

  # Add .gitkiss to .gitignore if not already there
  local gitignore="$repo_root/.gitignore"
  if [[ ! -f "$gitignore" ]] || ! grep -qx '.gitkiss' "$gitignore"; then
    echo '.gitkiss' >> "$gitignore"
    success "Added .gitkiss to .gitignore"
  fi
}

# ─── Worktree Commands ──────────────────────────────────────────────────────

WT_PATHS=()
WT_BRANCHES=()

parse_worktrees() {
  WT_PATHS=()
  WT_BRANCHES=()
  local path="" branch=""
  while IFS= read -r line; do
    case "$line" in
      worktree\ *)
        path="${line#worktree }"
        branch=""
        ;;
      branch\ *)
        branch="${line#branch refs/heads/}"
        ;;
      detached)
        branch="(detached)"
        ;;
      bare)
        path=""
        ;;
      "")
        if [[ -n "$path" ]]; then
          WT_PATHS+=("$path")
          WT_BRANCHES+=("${branch:-???}")
        fi
        path=""
        branch=""
        ;;
    esac
  done < <(git worktree list --porcelain; echo "")
}

repo_name() {
  basename "$(git rev-parse --show-toplevel)"
}

# Return the main worktree path (the original repo root)
main_worktree_path() {
  git worktree list --porcelain | head -1 | sed 's/^worktree //'
}

worktree_dir_name() {
  local name="$1"
  local main_path
  main_path="$(main_worktree_path)"
  local repo
  repo="$(basename "$main_path")"
  echo "$(dirname "$main_path")/${repo}--${name}"
}

copy_worktree_files() {
  local wt_path="$1"
  local main_path
  main_path="$(main_worktree_path)"

  if [[ -z "$WORKTREE_COPY" ]]; then
    return
  fi

  local copied=0
  local entry
  for entry in $WORKTREE_COPY; do
    local src="$main_path/$entry"
    local dest="$wt_path/$entry"

    if [[ ! -e "$src" ]]; then
      debug "worktree copy: skipping $entry (not found in main repo)"
      continue
    fi

    # Create parent directory if needed
    mkdir -p "$(dirname "$dest")"
    cp -a "$src" "$dest"
    debug "worktree copy: $entry"
    copied=$((copied + 1))
  done

  if [[ "$copied" -gt 0 ]]; then
    info "Copied $copied item(s) from WORKTREE_COPY config"
  fi
}

cmd_wt() {
  local subcmd="${1:-}"
  if [[ -z "$subcmd" ]]; then
    cmd_wt_help
    return
  fi
  shift

  case "$subcmd" in
    nf)    cmd_wt_nf "$@" ;;
    nb)    cmd_wt_nb "$@" ;;
    ls)    cmd_wt_ls "$@" ;;
    co)    cmd_wt_co "$@" ;;
    rm)    cmd_wt_rm "$@" ;;
    clean)  cmd_wt_clean "$@" ;;
    clean!) cmd_wt_clean --force "$@" ;;
    help|--help|-h) cmd_wt_help ;;
    *)
      error "Unknown worktree command: $subcmd"
      echo ""
      cmd_wt_help
      exit 1
      ;;
  esac
}

cmd_wt_nf() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    die "Usage: gk wt nf <feature-name>"
  fi

  name="$(echo "$name" | tr '[:upper:]' '[:lower:]' | tr ' ' '-')"

  if [[ -n "$INITIALS" ]]; then
    name="${INITIALS}-${name}"
  fi

  local branch_name="${FEATURE_PREFIX}${name}"
  local wt_path
  wt_path="$(worktree_dir_name "$name")"
  local base
  base="$(base_branch)"

  info "Fetching latest $base..."
  git fetch origin "$base"

  info "Creating worktree at $wt_path..."
  git worktree add "$wt_path" -b "$branch_name" "origin/$base"
  git -C "$wt_path" branch --unset-upstream 2>/dev/null || true
  copy_worktree_files "$wt_path"

  success "Worktree created at ${BOLD}$wt_path${NC}"
  echo -e "  cd $wt_path"
}

cmd_wt_nb() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    die "Usage: gk wt nb <branch-name>"
  fi

  name="$(echo "$name" | tr '[:upper:]' '[:lower:]' | tr ' ' '-')"

  local wt_path
  wt_path="$(worktree_dir_name "$name")"
  local base
  base="$(base_branch)"

  info "Fetching latest $base..."
  git fetch origin "$base"

  info "Creating worktree at $wt_path..."
  git worktree add "$wt_path" -b "$name" "origin/$base"
  git -C "$wt_path" branch --unset-upstream 2>/dev/null || true
  copy_worktree_files "$wt_path"

  success "Worktree created at ${BOLD}$wt_path${NC}"
  echo -e "  cd $wt_path"
}

cmd_wt_ls() {
  local base
  base="$(base_branch)"
  local current_wt
  current_wt="$(git rev-parse --show-toplevel)"

  parse_worktrees

  if [[ ${#WT_PATHS[@]} -eq 0 ]]; then
    info "No worktrees found."
    return
  fi

  # Header
  echo ""
  printf "  ${BOLD}%-4s %-30s %-40s %s${NC}\n" "#" "Branch" "Path" "Status"
  echo "  ─────────────────────────────────────────────────────────────────────────────────"

  local i
  for i in "${!WT_PATHS[@]}"; do
    local wt_path="${WT_PATHS[$i]}"
    local wt_branch="${WT_BRANCHES[$i]}"

    # Current marker
    local marker="  "
    if [[ "$wt_path" == "$current_wt" ]]; then
      marker="${GREEN}● ${NC}"
    fi

    # Dirty marker
    local dirty=""
    if [[ -d "$wt_path" ]]; then
      local status_output
      status_output="$(git -C "$wt_path" status --porcelain 2>/dev/null || echo "")"
      if [[ -n "$status_output" ]]; then
        dirty=" ${YELLOW}*${NC}"
      fi
    fi

    # Ahead/behind relative to base
    local ab=""
    if [[ "$wt_branch" != "(detached)" && "$wt_branch" != "???" ]]; then
      local ahead=0 behind=0
      ahead="$(git -C "$wt_path" rev-list --count "origin/$base..HEAD" 2>/dev/null || echo "0")"
      behind="$(git -C "$wt_path" rev-list --count "HEAD..origin/$base" 2>/dev/null || echo "0")"
      if [[ "$ahead" -gt 0 && "$behind" -gt 0 ]]; then
        ab="${GREEN}${ahead}↑${NC} ${RED}${behind}↓${NC}"
      elif [[ "$ahead" -gt 0 ]]; then
        ab="${GREEN}${ahead}↑${NC}"
      elif [[ "$behind" -gt 0 ]]; then
        ab="${RED}${behind}↓${NC}"
      fi
    fi

    printf "${marker}${BOLD}%-4s${NC} %-30s %-40s %s%s\n" "$i" "$wt_branch" "$wt_path" "$ab" "$dirty"
  done
  echo ""
}

cmd_wt_co() {
  local current_wt
  current_wt="$(git rev-parse --show-toplevel)"

  parse_worktrees

  if [[ ${#WT_PATHS[@]} -le 1 ]]; then
    info "No other worktrees to switch to." >&2
    return
  fi

  # Show numbered list (all UI on stderr so stdout stays clean for cd)
  echo "" >&2
  for i in "${!WT_PATHS[@]}"; do
    local wt_path="${WT_PATHS[$i]}"
    local wt_branch="${WT_BRANCHES[$i]}"

    if [[ "$wt_path" == "$current_wt" ]]; then
      printf "  ${GREEN}● %-4s${NC} %s\n" "$i" "$wt_branch" >&2
    else
      printf "    %-4s %s\n" "$i" "$wt_branch" >&2
    fi
  done
  echo "" >&2

  echo -n "Switch to [#]: " >&2
  read -r choice
  if [[ -z "$choice" ]]; then
    info "Aborted." >&2
    return
  fi

  if [[ ! "$choice" =~ ^[0-9]+$ ]] || [[ "$choice" -ge "${#WT_PATHS[@]}" ]]; then
    die "Invalid selection: $choice"
  fi

  local target="${WT_PATHS[$choice]}"
  if [[ "$target" == "$current_wt" ]]; then
    info "Already in that worktree." >&2
    return
  fi

  # Print path to stdout for cd
  echo "$target"
}

cmd_wt_rm() {
  local target="${1:-}"
  if [[ -z "$target" ]]; then
    die "Usage: gk wt rm <index|name>"
  fi

  parse_worktrees

  local rm_path="" rm_branch=""

  # Check if target is a number (index)
  if [[ "$target" =~ ^[0-9]+$ ]]; then
    if [[ "$target" -ge "${#WT_PATHS[@]}" ]]; then
      die "Index $target is out of range. Run 'gk wt ls' to see available worktrees."
    fi
    rm_path="${WT_PATHS[$target]}"
    rm_branch="${WT_BRANCHES[$target]}"
  else
    # Match by branch name (partial match)
    for i in "${!WT_BRANCHES[@]}"; do
      if [[ "${WT_BRANCHES[$i]}" == "$target" || "${WT_BRANCHES[$i]}" == *"$target"* ]]; then
        rm_path="${WT_PATHS[$i]}"
        rm_branch="${WT_BRANCHES[$i]}"
        break
      fi
    done
  fi

  if [[ -z "$rm_path" ]]; then
    die "Worktree not found: $target"
  fi

  # Don't allow removing the main worktree
  local main_path
  main_path="$(main_worktree_path)"
  if [[ "$rm_path" == "$main_path" ]]; then
    die "Cannot remove the main worktree."
  fi

  info "Removing worktree at $rm_path..."
  git worktree remove "$rm_path" --force

  # Delete branch if it was merged
  local base
  base="$(base_branch)"
  if [[ "$rm_branch" != "(detached)" && "$rm_branch" != "???" ]]; then
    if git branch --merged "$base" | grep -q "$rm_branch"; then
      git branch -d "$rm_branch" 2>/dev/null || true
      success "Worktree removed. Branch $rm_branch deleted (was merged)."
    else
      success "Worktree removed. Branch $rm_branch kept (not yet merged)."
    fi
  else
    success "Worktree removed."
  fi
}

cmd_wt_clean() {
  local force=false
  if [[ "${1:-}" == "--force" ]]; then
    force=true
    shift
  fi

  local base
  base="$(base_branch)"
  local main_path
  main_path="$(main_worktree_path)"

  parse_worktrees

  # Collect merged worktrees
  local -a clean_paths=()
  local -a clean_branches=()
  for i in "${!WT_PATHS[@]}"; do
    local wt_path="${WT_PATHS[$i]}"
    local wt_branch="${WT_BRANCHES[$i]}"

    # Skip main worktree
    if [[ "$wt_path" == "$main_path" ]]; then
      continue
    fi

    # Skip detached / unknown
    if [[ "$wt_branch" == "(detached)" || "$wt_branch" == "???" ]]; then
      continue
    fi

    # Check if merged
    if git branch --merged "$base" | grep -q "$wt_branch"; then
      clean_paths+=("$wt_path")
      clean_branches+=("$wt_branch")
    fi
  done

  if [[ ${#clean_paths[@]} -eq 0 ]]; then
    info "No merged worktrees to clean up."
    return
  fi

  # List worktrees that will be removed
  warn "The following merged worktrees will be removed:"
  echo ""
  for i in "${!clean_paths[@]}"; do
    echo "  - ${clean_branches[$i]} (${clean_paths[$i]})"
  done
  echo ""

  if [[ "$force" != true ]]; then
    read -r -p "Proceed? [y/N] " confirm
    if [[ "$confirm" != [yY] ]]; then
      info "Aborted."
      return
    fi
  fi

  local removed=0
  for i in "${!clean_paths[@]}"; do
    info "Removing ${clean_branches[$i]} (${clean_paths[$i]})..."
    git worktree remove "${clean_paths[$i]}" --force 2>/dev/null || true
    git branch -d "${clean_branches[$i]}" 2>/dev/null || true
    success "Removed ${clean_branches[$i]}"
    removed=$((removed + 1))
  done

  success "Cleaned up $removed worktree(s)."
}

cmd_wt_help() {
  cat <<EOF
${BOLD}git-kiss worktree${NC} — manage git worktrees

${BOLD}USAGE${NC}
  gk wt <command> [args]

${BOLD}COMMANDS${NC}
  nf <name>          New worktree with feature branch (uses prefix + initials)
  nb <name>          New worktree with plain branch
  ls                 List all worktrees with status
  co                 Checkout a worktree (interactive selector)
  rm <index|name>    Remove a worktree by index or branch name
  clean              Remove all worktrees with merged branches

${BOLD}EXAMPLES${NC}
  gk wt nf login          Create worktree with feature/mj-login branch
  gk wt nb hotfix-db       Create worktree with hotfix-db branch
  gk wt ls                 List worktrees (numbered)
  gk wt co                 Checkout a worktree interactively
  gk wt rm 2               Remove worktree #2
  gk wt rm login           Remove worktree matching "login"
  gk wt clean              Clean up merged worktrees

${BOLD}CONFIG${NC}
  WORKTREE_COPY      Space-separated list of files/folders to copy into new worktrees.
                     Useful for gitignored files like .gitkiss, .env, etc.
                     Example: WORKTREE_COPY=".gitkiss .env config/local"

${BOLD}TIP${NC}
  Add this alias to your shell profile to switch worktrees with cd:
  alias wtco='cd \$(gk wt co)'

EOF
}

cmd_help() {
  cat <<EOF
${BOLD}git-kiss${NC} v${VERSION} — Keep It Simple, Stupid git flow

${BOLD}USAGE${NC}
  gk <command> [args]

${BOLD}COMMANDS${NC}
  nf <name>    New feature branch
  ff           Finish current feature (merge into base branch, prompt to push)
  ff!          Finish current feature (merge and push)
  sf           Squash feature commits (rebase + squash, with prompt)
  sf!          Squash feature commits (no prompt)
  cm <msg>     Add all changes and commit with message
  pf           Publish feature branch to remote
  pr <title>   Create a pull request (requires gh CLI)
  rf           Rebase feature branch against base branch
  ds           Deploy to staging (prompt to force push)
  ds!          Deploy to staging (force push automatically)
  dp           Deploy to production (tag release, prompt to push)
  dp!          Deploy to production (tag release and push)
  wt <cmd>     Worktree management (run 'gk wt help' for details)
  init         Initialize .gitkiss config in current repo

${BOLD}CONFIG${NC}
  Global:  ~/.git-kiss
  Repo:    .gitkiss (overrides global)

  Run ${BOLD}gk init${NC} to generate a config file.

EOF
}

cmd_version() {
  echo "gk v${VERSION}"
}

# ─── Dispatcher ──────────────────────────────────────────────────────────────

main() {
  debug "gk v${VERSION} — $(bash --version | head -1)"
  require_git_repo
  load_config

  local cmd="${1:-help}"
  shift || true
  debug "command: gk $cmd $*"

  case "$cmd" in
    nf)       cmd_nf "$@" ;;
    ff)       cmd_ff "$@" ;;
    'ff!')    cmd_ff --force "$@" ;;
    sf)       cmd_fs "$@" ;;
    'sf!')    cmd_fs --force "$@" ;;
    cm)       cmd_cm "$@" ;;
    pf)       cmd_pf "$@" ;;
    pr)       cmd_pr "$@" ;;
    dp)       cmd_dp "$@" ;;
    'dp!')    cmd_dp --force "$@" ;;
    ds)       cmd_ds "$@" ;;
    'ds!')    cmd_ds --force "$@" ;;
    rf)       cmd_rf "$@" ;;
    wt)       cmd_wt "$@" ;;
    init)     cmd_init "$@" ;;
    help|--help|-h)    cmd_help ;;
    version|--version) cmd_version ;;
    *)
      error "Unknown command: $cmd"
      echo ""
      cmd_help
      exit 1
      ;;
  esac
}

main "$@"

# Post-command version check (once per day, non-blocking on failure)
check_version || true
